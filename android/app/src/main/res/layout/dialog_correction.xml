<?xml version="1.0" encoding="utf-8"?>
<!--
  Correction picker (I-134 tolerant-of-absence: renders from already-loaded item
  data first). Two paths in one dialog: (1) native remote-search — type a title,
  tap a candidate, apply; (2) browser fallback — open TMDb in a browser, paste the
  provider id back, apply. Classic Views idiom (no Compose), styled off the theme.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/correction_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="Currently matched to: The Matrix Reloaded (2003)" />

        <!-- Native remote search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/correction_search_field"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/correction_search_hint"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:importantForAutofill="no"
                tools:ignore="LabelFor" />

            <Button
                android:id="@+id/correction_search_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/correction_search_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/correction_search_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone"
            tools:text="Searching…"
            tools:visibility="visible" />

        <!-- Candidate results (rows added programmatically). -->
        <LinearLayout
            android:id="@+id/correction_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp"
            android:divider="@color/jf_divider"
            android:showDividers="middle" />

        <!-- Browser fallback -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/jf_divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="@string/correction_fallback_title" />

        <Button
            android:id="@+id/correction_tmdb_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/correction_fallback_tmdb_button" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="@string/correction_fallback_help" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/correction_paste_field"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/correction_fallback_paste_hint"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no"
                tools:ignore="LabelFor" />

            <Button
                android:id="@+id/correction_paste_apply_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/correction_fallback_apply_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/correction_apply_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="13sp"
            android:textColor="@color/jf_state_accent"
            android:visibility="gone"
            tools:text="Applying…"
            tools:visibility="visible" />
    </LinearLayout>
</ScrollView>
