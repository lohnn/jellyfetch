<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      usesCleartextTraffic (below) is a deliberate, load-bearing choice, not
      an oversight: the server URL is arbitrary user input at RUNTIME (see
      README "Server URL"), typically a bare LAN/Tailscale IP such as
      http://192.168.1.10:8096 with no TLS. Android's alternative,
      networkSecurityConfig, only allows/denies cleartext per statically
      known domain — it cannot express "any private/LAN address the user
      types in", so it cannot narrow this without breaking the app's core
      use case. Removing this flag silently breaks every plain-http
      self-hosted server (the common case). Re-evaluate only if the app
      gains a fixed/known-domain deployment mode. See README "Cleartext
      traffic (http://)" for the full rationale.
    -->
    <application
        android:name=".JellyFetchApp"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:theme="@style/Theme.JellyFetch"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <!-- Dashboard -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

        <activity
            android:name=".JobDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="@string/job_detail_title" />

        <activity
            android:name=".AllItemsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="@string/all_items_title" />

        <!-- The front door: catches shares and view intents from anywhere. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.JellyFetch.Dialog"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTop">

            <!-- 1. Share sheet: plain text (URLs from SVT Play / YouTube apps /
                 browsers — often wrapped in prose; we extract the first URL). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- 2. Share sheet: .torrent files as content URIs. File managers
                 and browsers are sloppy with torrent MIME, so we also accept
                 octet-stream and validate the payload in-app (bencode sniff +
                 filename check). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/x-bittorrent" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>

            <!-- 3. Open with: magnet links tapped in browsers. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="magnet" />
            </intent-filter>

            <!-- 4. Open with: .torrent files by proper MIME type. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/x-bittorrent" />
            </intent-filter>

            <!-- 5. Open with: .torrent files by filename-extension fallback,
                 because file managers/browsers frequently send octet-stream or
                 no MIME at all. pathPattern quirks: host must be set for path
                 matching to apply, matching is against the URI path only (many
                 content providers expose opaque paths — this is best-effort),
                 and .* is non-greedy-ish (won't cross multiple dots), hence the
                 repeated patterns. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.torrent" />
                <data android:pathPattern=".*\\..*\\.torrent" />
                <data android:pathPattern=".*\\..*\\..*\\.torrent" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.torrent" />
            </intent-filter>
        </activity>
    </application>
</manifest>
